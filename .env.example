NODE_ENV=development
PORT=3000

# PostgreSQL (obrigatório em produção)
DATABASE_URL=postgresql://user:password@localhost:5432/trackflow

JWT_SECRET=trocar-por-segredo-longo-em-producao

# Rate limiting (opcional)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# Redis — analytics cache (opcional; sem isto usa cache em memória no processo)
REDIS_URL=redis://localhost:6379
ANALYTICS_CACHE_TTL_MS=60000

# CORS: lista separada por vírgula ou omita para "*"
# CORS_ORIGIN=http://localhost:3000,https://app.seudominio.com

# Limite de heap para /health/ready (MB)
HEALTH_HEAP_LIMIT_MB=1536
